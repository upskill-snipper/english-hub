{
  "cli": {
    "version": ">= 7.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "node": "20.11.1",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://theenglishhub.app",
        "EXPO_PUBLIC_REVENUECAT_IOS_API_KEY": "$EAS_REVENUECAT_IOS_API_KEY",
        "EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY": "$EAS_REVENUECAT_ANDROID_API_KEY"
      }
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "ios": {
        "simulator": true,
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "apk",
        "resourceClass": "medium"
      }
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "channel": "preview",
      "ios": {
        "simulator": false,
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "apk",
        "resourceClass": "medium"
      }
    },
    "production": {
      "extends": "base",
      "channel": "production",
      "autoIncrement": true,
      "ios": {
        "image": "latest",
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "app-bundle",
        "resourceClass": "medium"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "bundleIdentifier": "app.theenglishhub.mobile",
        "ascAppId": "6765644554",
        "appleId": "calumjohnson@hotmail.com",
        "appleTeamId": "645XBAPVHK",
        "language": "en-GB"
      },
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "internal",
        "releaseStatus": "draft"
      }
    }
  }
}
