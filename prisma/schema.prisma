// Prisma schema for The English Hub - EdTech SaaS Platform
// PostgreSQL provider with privacy-first defaults

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ──────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────

enum Role {
  STUDENT
  ADMIN
  REVIEWER
  TEACHER
  PARENT
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum ConsentType {
  TERMS
  PRIVACY
  AI_PROCESSING
  DATA_TRANSFER
  MARKETING
  COOLING_OFF_WAIVER
  COOKIE_ANALYTICS
  COOKIE_MARKETING
}

enum ConsentMethod {
  ACTIVE_CHECKBOX
  EXPLICIT
}

enum Subject {
  LANGUAGE
  LITERATURE
}

enum ExamBoard {
  AQA
  EDEXCEL
  OCR
  EDUQAS
  EDEXCEL_IGCSE
  CAMBRIDGE_0500
  CAMBRIDGE_0990
}

enum SuggestionType {
  SUGGESTION
  BUG_REPORT
  FEEDBACK
}

enum SuggestionStatus {
  PENDING
  REVIEWED
  RESOLVED
}

enum ReviewReason {
  DISAGREE_WITH_SCORE
  FEEDBACK_UNCLEAR
  TECHNICAL_ERROR
  BIAS_CONCERN
  OTHER
}

enum ReviewStatus {
  SUBMITTED
  UNDER_REVIEW
  COMPLETED
}

enum SubscriptionPlan {
  MONTHLY
  ANNUAL
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  TRIALING
  PAUSED
}

// Billing rail that owns the active entitlement on a Subscription row.
// WEB = Stripe-owned (existing path); IOS/ANDROID = RevenueCat-reconciled.
enum SubscriptionPlatform {
  WEB
  IOS
  ANDROID
}

enum ReminderType {
  MONTHLY_6TH
  ANNUAL_RENEWAL
  TRIAL_ENDING
}

enum DataRequestType {
  ACCESS
  PORTABILITY
  ERASURE
  RECTIFICATION
}

enum DataRequestStatus {
  PENDING
  PROCESSING
  COMPLETED
  REFUSED
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ProfileVisibility {
  PRIVATE
  SCHOOL_ONLY
  PUBLIC
}

// ──────────────────────────────────────────────
// Models
// ──────────────────────────────────────────────

model User {
  id                String        @id @default(cuid())
  // supabaseUserId: links this Prisma User row to the Supabase auth.users
  // row that owns the identity (email + password hash + MFA factors).
  // Added in Cycle 4 PR-1 (identity convergence plan). Nullable for the
  // transition window; every endpoint that currently joins by email
  // should read this instead once PR-3 ships, and a follow-up migration
  // flips it to NOT NULL once backfill is verified. See
  // EH_QA_MASTER_LOG.md Cycle 3 schema convergence plan.
  supabaseUserId    String?       @unique @db.Uuid
  email             String        @unique
  passwordHash      String
  firstName         String
  lastName          String
  dateOfBirth       DateTime
  school            String?
  role              Role          @default(STUDENT)
  selectedExamBoard ExamBoard?
  isMinor           Boolean       @default(false) @map("is_minor")
  country           String
  accountStatus     AccountStatus @default(ACTIVE)
  parentId          String?
  linkedTeacherId   String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  // lastLoginAt: set by the login handler on successful Supabase sign-in.
  // Cycle 2 P1 flagged that the dormancy check was using `updatedAt` as a
  // proxy, which bumps on any profile update (email change, theme, etc.)
  // and wrongly resets the 730-day inactive clock. Now driven by real
  // login events. Nullable because pre-migration rows have no signal.
  lastLoginAt       DateTime?
  deletedAt         DateTime?
  // Mobile telemetry (Wave 4). Denormalised hot-path reads — the
  // authoritative per-device record lives in MobileDevice. mobileDeviceCount
  // is maintained by trigger on MobileDevice insert/revoke. pushTokens is an
  // array of { token, platform, deviceId, addedAt } used for Expo push fan-out.
  mobileDeviceCount Int           @default(0) @map("mobile_device_count")
  pushTokens        Json          @default("[]") @map("push_tokens")
  lastMobileVersion String?       @map("last_mobile_version")

  parent                 User?                   @relation("ParentChild", fields: [parentId], references: [id])
  children               User[]                  @relation("ParentChild")
  consents               Consent[]
  essays                 Essay[]
  humanReviewRequests    HumanReviewRequest[]
  subscription           Subscription?
  dataAccessRequests     DataAccessRequest[]
  safeguardingReports    SafeguardingReport[]    @relation("Reporter")
  assignedReports        SafeguardingReport[]    @relation("Assignee")
  auditLogs              AuditLog[]
  privacySettings        PrivacySettings?
  reviewedRequests       HumanReviewRequest[]    @relation("Reviewer")
  suggestions            Suggestion[]
  weeklyReportsAsParent  WeeklyReport[]          @relation("ParentReports")
  weeklyReportsAsStudent WeeklyReport[]          @relation("StudentReports")
  parentInvitesSent      ParentInvite[]          @relation("StudentInvites")
  parentInvitesUsed      ParentInvite[]          @relation("ParentInviteUsed")
  mobileDevices          MobileDevice[]
  offlineEssayQueueItems OfflineEssayQueueItem[]
  markingSubmissions     MarkingSubmission[]     @relation("MarkingSubmissionStudent")

  @@index([email])
  @@index([role])
  @@index([accountStatus])
  @@index([deletedAt])
  @@index([school])
  @@index([parentId])
  @@index([linkedTeacherId])
}

model Consent {
  id          String        @id @default(cuid())
  userId      String
  consentType ConsentType
  version     String
  granted     Boolean
  grantedAt   DateTime      @default(now())
  withdrawnAt DateTime?
  method      ConsentMethod
  ipAddress   String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([consentType])
  @@index([userId, consentType])
}

model CookieConsent {
  id          String   @id @default(cuid())
  visitorId   String
  userId      String?
  choice      String // "accept_all" | "reject_all" | "custom"
  analytics   Boolean  @default(false)
  marketing   Boolean  @default(false)
  ipHash      String // SHA-256 hash of client IP — never store raw IP
  userAgent   String?
  consentedAt DateTime @default(now())
  version     String

  @@index([visitorId])
  @@index([userId])
  @@index([consentedAt])
}

model Essay {
  id        String    @id @default(cuid())
  userId    String
  title     String
  content   String    @db.Text
  subject   Subject
  examBoard ExamBoard
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  aiFeedback          AIFeedback?
  humanReviewRequests HumanReviewRequest[]

  @@index([userId])
  @@index([subject])
  @@index([examBoard])
  @@index([deletedAt])
  @@index([userId, createdAt])
  @@index([userId, deletedAt, createdAt])
}

model AIFeedback {
  id              String   @id @default(cuid())
  essayId         String   @unique
  overallScore    Float
  grammarScore    Float
  structureScore  Float
  argumentScore   Float
  vocabularyScore Float
  feedbackText    String   @db.Text
  criteria        String   @db.Text
  limitations     String   @db.Text
  modelVersion    String
  createdAt       DateTime @default(now())

  essay               Essay                @relation(fields: [essayId], references: [id], onDelete: Cascade)
  humanReviewRequests HumanReviewRequest[]

  @@index([essayId])
}

model HumanReviewRequest {
  id               String       @id @default(cuid())
  essayId          String
  userId           String
  aiFeedbackId     String
  reason           ReviewReason
  reasonDetail     String       @db.Text
  selfAssessment   String?      @db.Text
  status           ReviewStatus @default(SUBMITTED)
  referenceNumber  String       @unique
  reviewerResponse String?      @db.Text
  reviewedById     String?
  submittedAt      DateTime     @default(now())
  reviewedAt       DateTime?

  essay      Essay      @relation(fields: [essayId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  aiFeedback AIFeedback @relation(fields: [aiFeedbackId], references: [id], onDelete: Cascade)
  reviewer   User?      @relation("Reviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([essayId])
  @@index([userId])
  @@index([aiFeedbackId])
  @@index([status])
  @@index([referenceNumber])
  @@index([reviewedById])
}

model Subscription {
  id                      String               @id @default(cuid())
  userId                  String               @unique
  // Stripe identity columns — NULL on mobile (RevenueCat-reconciled) rows.
  // Made optional in 20260420_02_stripe_columns_nullable.sql so the mobile
  // reconciler no longer needs to synthesise `rc_*` sentinel strings.
  stripeCustomerId        String?
  stripeSubscriptionId    String?              @unique
  plan                    SubscriptionPlan
  status                  SubscriptionStatus   @default(TRIALING)
  currentPeriodStart      DateTime
  currentPeriodEnd        DateTime
  cancelledAt             DateTime?
  // Set by the RevenueCat REFUND / CHARGEBACK reconciler. Distinct from
  // cancelledAt (user auto-renew off) so refund-driven revocation is queryable.
  refundedAt              DateTime?            @map("refunded_at")
  coolingOffWaived        Boolean              @default(false)
  coolingOffWaivedAt      DateTime?
  paymentCount            Int                  @default(0)
  isTeacherPlan           Boolean              @default(false)
  maxStudents             Int?
  teacherPriceId          String?
  // RevenueCat reconciliation fields (Wave 4). Populated by the mobile
  // webhook handler when a Subscription row represents an iOS/Android
  // IAP rather than a Stripe subscription. Nullable on web-originated rows.
  revenuecatAppUserId     String?              @map("revenuecat_app_user_id")
  revenuecatProductId     String?              @map("revenuecat_product_id")
  platform                SubscriptionPlatform @default(WEB)
  originalPurchaseDate    DateTime?            @map("original_purchase_date")
  // Grandfathering columns (R-031, 2026-04-21). Captured at signup, preserved
  // across renewals so Early Access subscribers keep their locked price even
  // after the Aug 2026 Standard rollover. See
  // `src/lib/pricing/grandfather.ts` for capture logic and
  // `supabase/migrations/20260421_01_subscription_grandfather_price.sql`.
  grandfatheredPriceMinor Int?                 @map("grandfathered_price_minor")
  grandfatheredCurrency   String?              @map("grandfathered_currency") @db.Char(3)
  pricingTier             String?              @map("pricing_tier")

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  renewalReminders RenewalReminder[]

  @@index([userId])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
  @@index([status])
}

model RenewalReminder {
  id              String       @id @default(cuid())
  subscriptionId  String
  sentAt          DateTime     @default(now())
  type            ReminderType
  amount          Float
  currency        String
  nextPaymentDate DateTime

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([type])
  @@index([nextPaymentDate])
}

model DataAccessRequest {
  id              String            @id @default(cuid())
  userId          String
  type            DataRequestType
  status          DataRequestStatus @default(PENDING)
  requestedAt     DateTime          @default(now())
  completedAt     DateTime?
  responseDetails String?           @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([type])
}

model SafeguardingReport {
  id          String    @id @default(cuid())
  reporterId  String?
  reportType  String
  description String    @db.Text
  severity    Severity
  status      String    @default("OPEN")
  createdAt   DateTime  @default(now())
  assignedTo  String?
  resolvedAt  DateTime?

  reporter User? @relation("Reporter", fields: [reporterId], references: [id], onDelete: SetNull)
  assignee User? @relation("Assignee", fields: [assignedTo], references: [id], onDelete: SetNull)

  @@index([reporterId])
  @@index([severity])
  @@index([status])
  @@index([assignedTo])
  @@index([createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  resource   String
  resourceId String
  details    Json?
  ipAddress  String
  timestamp  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([resource, resourceId])
  @@index([timestamp])
  @@index([userId, timestamp(sort: Desc)])
}

model PrivacySettings {
  id                   String            @id @default(cuid())
  userId               String            @unique
  analyticsEnabled     Boolean           @default(false)
  marketingEnabled     Boolean           @default(false)
  aiTrainingOptIn      Boolean           @default(false)
  aiOptOut             Boolean           @default(false)
  schoolSharingEnabled Boolean           @default(false)
  researchDataEnabled  Boolean           @default(false)
  profileVisibility    ProfileVisibility @default(PRIVATE)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Suggestion {
  id        String           @id @default(cuid())
  type      SuggestionType
  subject   String
  message   String           @db.Text
  page      String?
  userId    String?
  email     String?
  status    SuggestionStatus @default(PENDING)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model ParentInvite {
  id             String    @id @default(cuid())
  code           String    @unique
  studentId      String
  expiresAt      DateTime
  usedAt         DateTime?
  usedByParentId String?
  createdAt      DateTime  @default(now())

  student User  @relation("StudentInvites", fields: [studentId], references: [id], onDelete: Cascade)
  usedBy  User? @relation("ParentInviteUsed", fields: [usedByParentId], references: [id], onDelete: SetNull)

  @@index([code])
  @@index([studentId])
  @@index([expiresAt])
  @@index([usedByParentId])
}

// ──────────────────────────────────────────────
// Assignment & Submission
// ──────────────────────────────────────────────

enum AssignmentType {
  HOMEWORK
  CLASSWORK
  ASSESSMENT
  REVISION
}

enum AssignmentStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum SubmissionStatus {
  PENDING
  SUBMITTED
  GRADED
}

model Assignment {
  id          String           @id @default(cuid())
  classId     String
  teacherId   String
  title       String
  description String?          @db.Text
  type        AssignmentType
  status      AssignmentStatus @default(ACTIVE)
  courseId    String?
  moduleIds   String[]
  dueDate     DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  submissions AssignmentSubmission[]

  @@index([classId])
  @@index([teacherId])
  @@index([status])
  @@index([dueDate])
  @@index([classId, status])
}

model AssignmentSubmission {
  id           String           @id @default(cuid())
  assignmentId String
  studentId    String
  status       SubmissionStatus @default(PENDING)
  score        Float?
  feedback     String?          @db.Text
  submittedAt  DateTime?
  gradedAt     DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
  @@index([assignmentId])
  @@index([studentId])
  @@index([status])
}

model WeeklyReport {
  id              String   @id @default(cuid())
  parentId        String
  studentId       String
  weekStarting    DateTime
  essaysCompleted Int
  totalTimeSpent  Int
  averageScore    Float?
  projectedGrade  String?
  strengths       Json?
  weaknesses      Json?
  recommendations Json?
  sentAt          DateTime @default(now())

  parent  User @relation("ParentReports", fields: [parentId], references: [id], onDelete: Cascade)
  student User @relation("StudentReports", fields: [studentId], references: [id], onDelete: Cascade)

  @@index([parentId])
  @@index([studentId])
  @@index([weekStarting])
  @@index([parentId, weekStarting])
}

// ──────────────────────────────────────────────
// Mobile / RevenueCat (Wave 4 prerequisite)
// ──────────────────────────────────────────────
//
// Additive, non-breaking contributions from the mobile contribution plan.
// FeatureFlag is intentionally deferred to a later wave — see DB_SCHEMA.md §4.3.

// Platform enum for a registered mobile device. Distinct from
// SubscriptionPlatform because a device is never "WEB" in practice, but we
// keep the same vocabulary for parity with the billing platform field.
enum DevicePlatform {
  IOS
  ANDROID
  WEB
}

// One row per (user, device). A reinstall produces a new deviceId and
// therefore a new row — identity is never mutated, only revoked and recreated.
model MobileDevice {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String         @map("user_id")
  deviceId     String         @map("device_id")
  platform     DevicePlatform
  osVersion    String?        @map("os_version")
  appVersion   String?        @map("app_version")
  pushToken    String?        @map("push_token")
  lastActiveAt DateTime       @default(now()) @map("last_active_at") @db.Timestamptz(6)
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  revokedAt    DateTime?      @map("revoked_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([userId, lastActiveAt])
  @@map("MobileDevice")
}

// Immutable journal for every inbound RevenueCat webhook. We persist BEFORE
// processing so we can replay idempotently if the handler crashes mid-reconcile.
// Append-only; processedAt / processingError are stamped by the worker.
model RevenueCatEvent {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventType       String    @map("event_type")
  appUserId       String    @map("app_user_id")
  productId       String?   @map("product_id")
  payload         Json
  receivedAt      DateTime  @default(now()) @map("received_at") @db.Timestamptz(6)
  processedAt     DateTime? @map("processed_at") @db.Timestamptz(6)
  processingError String?   @map("processing_error")

  @@index([appUserId, eventType])
  @@map("RevenueCatEvent")
}

// Essays drafted on-device while offline. The client holds a local SQLite
// mirror; on reconnect each record is pushed here and a server cron forwards
// queued rows to the marking pipeline. The double-hop exists so the device
// can be powered off between writing an essay and network availability.
model OfflineEssayQueueItem {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String    @map("user_id")
  deviceId    String    @map("device_id")
  payload     Json
  attempts    Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  submittedAt DateTime? @map("submitted_at") @db.Timestamptz(6)
  failedAt    DateTime? @map("failed_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("OfflineEssayQueueItem")
}

// ──────────────────────────────────────────────
// School bulk-upload job log (Wave 5, web-only)
// ──────────────────────────────────────────────
//
// Every run of POST /api/school/bulk-upload/commit writes a row here before
// performing the transactional upsert, then stamps completedAt at the end.
// The errorsJson column stores the per-row ParseError[] so admins can re-view
// failed imports without re-uploading. The idempotencyKey column lets clients
// safely retry the same commit — a second request with the same key returns
// the first response verbatim.
//
// Not user-scoped data; retention follows the school-admin audit policy and is
// purged when a school licence ends.
model BulkUploadJob {
  id             String    @id @default(cuid())
  adminUserId    String    @map("admin_user_id")
  schoolId       String    @map("school_id")
  fileName       String    @map("file_name")
  idempotencyKey String    @unique @map("idempotency_key")
  rowCount       Int       @default(0) @map("row_count")
  successCount   Int       @default(0) @map("success_count")
  errorCount     Int       @default(0) @map("error_count")
  createdCount   Int       @default(0) @map("created_count")
  updatedCount   Int       @default(0) @map("updated_count")
  skippedCount   Int       @default(0) @map("skipped_count")
  errorsJson     Json?     @map("errors_json")
  status         String    @default("pending")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  completedAt    DateTime? @map("completed_at") @db.Timestamptz(6)

  @@index([adminUserId])
  @@index([schoolId, createdAt(sort: Desc)])
  @@map("BulkUploadJob")
}

// ──────────────────────────────────────────────
// School Marking Submissions (Wave 5)
// ──────────────────────────────────────────────
//
// One row per student essay submitted into the school marking pipeline.
// Written by `/api/school/marking` and updated by `/api/school/marking/override`.
// Reads happen exclusively through the Supabase client (the route never
// uses the Prisma client for this table) because authorisation is enforced
// via RLS keyed on auth.uid() and school_members; the Prisma model exists
// so the schema ships the column shape and a Prisma migration can be
// applied alongside the Supabase mirror.
//
// Notes on relations:
//   • `studentId` is a Supabase auth.users UUID. It maps to the Prisma
//     User row via the unique `supabaseUserId` column (see User above).
//   • `schoolId` / `classId` / `teacherReviewedById` reference Supabase-only
//     tables (`schools`, `classes`, `school_members`) which are not modelled
//     in Prisma. The FK constraints exist in the SQL migration but cannot
//     be expressed in Prisma here.
model MarkingSubmission {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId            String    @map("school_id") @db.Uuid
  studentId           String    @map("student_id") @db.Uuid
  classId             String?   @map("class_id") @db.Uuid
  examBoard           String    @map("exam_board")
  essayTitle          String?   @map("essay_title")
  essayText           String    @map("essay_text") @db.Text
  aiGrade             String?   @map("ai_grade")
  aiConfidence        Float?    @map("ai_confidence")
  aiFeedback          String?   @map("ai_feedback") @db.Text
  aiBandMarks         Json      @default("[]") @map("ai_band_marks")
  status              String    @default("pending")
  submittedAt         DateTime  @default(now()) @map("submitted_at") @db.Timestamptz(6)
  teacherGrade        String?   @map("teacher_grade")
  teacherComment      String?   @map("teacher_comment") @db.Text
  teacherReviewedById String?   @map("teacher_reviewed_by") @db.Uuid
  teacherReviewedAt   DateTime? @map("teacher_reviewed_at") @db.Timestamptz(6)

  student User? @relation("MarkingSubmissionStudent", fields: [studentId], references: [supabaseUserId], onDelete: NoAction, onUpdate: NoAction)

  @@index([schoolId, submittedAt(sort: Desc)])
  @@index([studentId])
  @@index([classId])
  @@map("marking_submissions")
}
