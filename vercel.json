{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "regions": ["lhr1"],
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/affiliate-confirm",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/affiliate-confirm-v2",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/expire-invites",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/dormancy-check",
      "schedule": "30 3 * * *"
    },
    {
      "path": "/api/cron/dormancy-purge",
      "schedule": "0 4 * * 0"
    },
    {
      "path": "/api/cron/data-retention",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/weekly-student-reports",
      "schedule": "0 17 * * 0"
    },
    {
      "path": "/api/cron/weekly-reports",
      "schedule": "0 7 * * 1"
    },
    {
      "path": "/api/cron/weekly-parent-reports",
      "schedule": "0 16 * * 0"
    },
    {
      "path": "/api/cron/school-access",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/trustpilot-followup-7d",
      "schedule": "45 3 * * *"
    },
    {
      "path": "/api/cron/trustpilot-retention-90d",
      "schedule": "15 4 * * *"
    },
    {
      "path": "/api/cron/trustpilot-retention-invite",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cron/blog-generate",
      "schedule": "0 */12 * * *"
    }
  ]
}
