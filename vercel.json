{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "regions": ["lhr1"],
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/affiliate-confirm",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/expire-invites",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/dormancy-check",
      "schedule": "30 3 * * *"
    },
    {
      "path": "/api/cron/data-retention",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/weekly-reports",
      "schedule": "0 7 * * 1"
    },
    {
      "path": "/api/cron/school-access",
      "schedule": "0 5 * * *"
    }
  ]
}
