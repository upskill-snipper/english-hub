{
  "name": "english-hub",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && NODE_OPTIONS='--max-old-space-size=8192' next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "next lint",
    "prepare": "husky",
    "sbom": "cyclonedx-npm --output-file sbom.json",
    "analyze": "ANALYZE=true next build",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject ./.next && sentry-cli sourcemaps upload ./.next"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ],
    "*.{ts,tsx,json,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@base-ui/react": "^1.3.0",
    "@prisma/client": "^6.19.2",
    "@sentry/nextjs": "^10.44.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.2",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "docx": "^9.6.1",
    "dompurify": "^3.3.3",
    "lucide-react": "^0.577.0",
    "next": "^15.5.15",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.13",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sonner": "^2.0.7",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@cyclonedx/cyclonedx-npm": "^1.20.0",
    "@next/bundle-analyzer": "^14.2.35",
    "@playwright/test": "^1.52.0",
    "@sentry/cli": "^2.42.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.5.15",
    "husky": "^9.1.0",
    "jsdom": "^29.0.0",
    "lint-staged": "^15.4.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.3",
    "prisma": "^6.19.2",
    "shadcn": "^4.1.0",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
