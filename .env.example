# ============================================================================
# The English Hub - Environment Variables
# ============================================================================
# Copy this file to .env.local for local development.
# In production, set these in Vercel Dashboard > Settings > Environment Variables.
#
# Legend:
#   [REQUIRED]  - App will crash in production without this
#   [REQUIRED*] - Feature-critical; app starts but key functionality breaks
#   [OPTIONAL]  - App works without it; logs a warning at startup
# ============================================================================

# ── Supabase ────────────────────────────────────────────────────────────────

# [REQUIRED] Supabase project URL (Settings > API > Project URL)
NEXT_PUBLIC_SUPABASE_URL=

# [REQUIRED] Supabase anonymous/public API key (Settings > API > anon key)
# Safe to expose client-side; all access is governed by RLS policies.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# [REQUIRED] Supabase service role key (Settings > API > service_role key)
# SERVER-ONLY. Bypasses RLS -- never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ── Prisma / Database ──────────────────────────────────────────────────────

# [REQUIRED*] PostgreSQL connection string for Prisma ORM
# Format: postgresql://user:password@host:port/dbname
# Get this from Supabase Dashboard > Settings > Database > Connection string
DATABASE_URL=

# ── Stripe (Payments) ──────────────────────────────────────────────────────

# [REQUIRED] Stripe publishable key (client-side, safe to expose)
# Use test key (pk_test_...) for development, live key (pk_live_...) for production.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# [REQUIRED] Stripe secret key (server-only)
# Use test key (sk_test_...) for development, live key (sk_live_...) for production.
STRIPE_SECRET_KEY=

# [REQUIRED] Stripe webhook signing secret
# From Stripe Dashboard > Developers > Webhooks > your endpoint > Signing secret.
# Different for each endpoint (test vs live, local vs production).
STRIPE_WEBHOOK_SECRET=

# ── Stripe Price IDs ───────────────────────────────────────────────────────
# [OPTIONAL] Each maps to a Stripe Price object. Create in Stripe Dashboard > Products.
# Without these, the corresponding course/subscription won't appear in pricing.
#
# Run `npx tsx scripts/stripe-sync-products.ts` to audit which IDs are missing
# vs. canonical pricing in src/constants/pricing.ts. The script writes a
# diff report to business-docs/STRIPE-SYNC-REPORT.md and (with --apply)
# creates any missing prices via the Stripe API.

# Student tier — Early Access (current live signup price, £3.99/mo · £29.99/yr).
# Charged to every new student signup until the August 2026 standard cutover.
STRIPE_PRICE_STUDENT_MONTHLY=
STRIPE_PRICE_STUDENT_ANNUAL=

# Student tier — Standard (effective August 2026, £7.99/mo · £69.99/yr).
# Anchored on every price banner today; becomes the default charge from Aug 2026.
STRIPE_PRICE_STUDENT_MONTHLY_STANDARD=
STRIPE_PRICE_STUDENT_ANNUAL_STANDARD=

# Teacher tier — Early Access (£6.99/mo · £67.99/yr).
# Charged to every new teacher signup until the August 2026 standard cutover.
STRIPE_PRICE_TEACHER_MONTHLY=
STRIPE_PRICE_TEACHER_ANNUAL=

# Teacher tier — Standard (effective August 2026, £11.99/mo · £99/yr).
# Anchored on every price banner today; becomes the default charge from Aug 2026.
STRIPE_PRICE_TEACHER_MONTHLY_STANDARD=
STRIPE_PRICE_TEACHER_ANNUAL_STANDARD=

# Pro subscription plans (legacy alias retained for back-compat with src/lib/stripe.ts).
# New code should reference STRIPE_PRICE_STUDENT_* / STRIPE_PRICE_TEACHER_* instead.
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=

# AQA KS3 one-time courses
STRIPE_PRICE_KS3_READING=
STRIPE_PRICE_KS3_WRITING=
STRIPE_PRICE_KS3_GRAMMAR=

# AQA GCSE one-time courses
STRIPE_PRICE_GCSE_LANG_READING=
STRIPE_PRICE_GCSE_LANG_WRITING=
STRIPE_PRICE_GCSE_LIT_POETRY=
STRIPE_PRICE_GCSE_LIT_PROSE=
STRIPE_PRICE_GCSE_REVISION=

# Course bundle
STRIPE_PRICE_BUNDLE=

# Edexcel one-time courses
STRIPE_PRICE_EDEXCEL_LANG_P1=
STRIPE_PRICE_EDEXCEL_LANG_P2=
STRIPE_PRICE_EDEXCEL_LIT_P1=
STRIPE_PRICE_EDEXCEL_LIT_P2=
STRIPE_PRICE_EDEXCEL_IGCSE_A=
STRIPE_PRICE_EDEXCEL_IGCSE_B=

# ── AI / Anthropic ─────────────────────────────────────────────────────────

# [REQUIRED] Anthropic API key for Claude (essay feedback, AI features)
# From console.anthropic.com > API Keys
ANTHROPIC_API_KEY=

# ── Email (Resend) ─────────────────────────────────────────────────────────

# [REQUIRED*] Resend API key for transactional emails (welcome, password reset,
# weekly reports, dormancy warnings, school access alerts)
# From resend.com > API Keys
RESEND_API_KEY=

# ── Site URLs ──────────────────────────────────────────────────────────────

# [REQUIRED*] Public-facing app URL (used in emails, redirects, Open Graph tags)
NEXT_PUBLIC_APP_URL=https://theenglishhub.app

# [REQUIRED*] Site URL used in transactional email templates
NEXT_PUBLIC_SITE_URL=https://theenglishhub.app

# ── Security ───────────────────────────────────────────────────────────────

# [REQUIRED*] HMAC secret for CSRF token generation/validation
# Generate with: openssl rand -hex 32
CSRF_SECRET=

# [REQUIRED*] Salt for privacy-compliant IP address hashing
# Generate with: openssl rand -hex 16
IP_HASH_SALT=

# Affiliate click IP deduplication — HMAC-SHA256 hash of client IP
# Generate a strong 32+ character random string. Each environment
# (prod, staging) should have its own unique value. A rotating secret
# breaks cross-environment click-fraud deduplication but does not
# break already-persisted rows.
AFFILIATE_IP_HASH_SECRET=

# Cookie-consent IP hash — same purpose, different trust boundary.
# Keep distinct from AFFILIATE_IP_HASH_SECRET.
CONSENT_IP_HASH_SECRET=

# ── Cron Jobs ──────────────────────────────────────────────────────────────

# [REQUIRED*] Secret token for authenticating cron job requests
# Auto-set by Vercel on Pro/Enterprise plans. Set manually for local testing.
# Cron endpoints verify: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# ── Rate Limiting (Upstash Redis) ──────────────────────────────────────────

# [REQUIRED*] Upstash Redis REST endpoint and token for API rate limiting
# From console.upstash.com > your database > REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Admin ──────────────────────────────────────────────────────────────────

# [OPTIONAL] Comma-separated email addresses with admin access
ADMIN_EMAILS=admin@example.com

# [OPTIONAL] Comma-separated list of site-wide super-admin emails
SITE_ADMIN_EMAILS=admin@example.com

# ── Affiliate Tracking (Rewardful) ────────────────────────────────────────

# [OPTIONAL] Rewardful server-side API key (from Rewardful dashboard)
REWARDFUL_API_SECRET=

# [OPTIONAL] Rewardful client-side key (safe to expose, used for JS snippet)
NEXT_PUBLIC_REWARDFUL_KEY=

# [OPTIONAL] Email address for affiliate admin notifications
AFFILIATE_ADMIN_EMAIL=affiliates@theenglishhub.app

# ── Error Tracking (Sentry) ───────────────────────────────────────────────

# [OPTIONAL] Sentry DSN for client-side error reporting
NEXT_PUBLIC_SENTRY_DSN=

# [OPTIONAL] Sentry DSN for server-side error reporting
SENTRY_DSN=

# ── Analytics ──────────────────────────────────────────────────────────────

# [OPTIONAL] Google Analytics 4 measurement ID
# GA4 snippet is only injected when this is set.
NEXT_PUBLIC_GA4_ID=

# [OPTIONAL] PostHog EU — product analytics + funnel tracking.
# Events are consent-gated (PECR reg. 6) and suppressed for minor accounts
# (ICO Children's Code standard 15). See src/lib/posthog.ts.
# TODO(founder): full inventory of required env vars is tracked in
# business-docs/ENV-VAR-INVENTORY.md — add this pair there too.
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ── RevenueCat (mobile IAP reconciliation) ─────────────────────────────────

# [REQUIRED*] Bearer token configured in the RevenueCat dashboard
# (Integrations → Webhooks → Authorization header value, prefixed with
# "Bearer "). Validated by `src/lib/revenuecat/verify.ts` on every inbound
# delivery: RC sends `Authorization: Bearer <this-value>` and we check it
# in constant time against this env var. Live value lives in
# `secrets/revenuecat-webhook-secret.txt` (gitignored, file content =
# the part AFTER "Bearer ", no prefix). Rotate per environment.
REVENUECAT_WEBHOOK_SECRET=

# [REQUIRED*] Server-only REST API key (secret key) for server-to-RevenueCat
# reads — e.g. purchaser-info verification, manual entitlement grants. Never
# expose to the client; the mobile app uses a separate public SDK key.
REVENUECAT_SECRET_API_KEY=

# [REQUIRED*] Apple App-Specific Shared Secret for iOS receipt validation.
# Generated in App Store Connect → My Apps → The English Hub → App Information
# → App-Specific Shared Secret → Generate. RevenueCat (not our backend) uses
# this secret to verify receipts against Apple's servers. Generate AFTER the
# four IAP products exist; otherwise ASC won't show the option.
REVENUECAT_APPLE_SHARED_SECRET=

# ── Apple (iOS app distribution + push) ─────────────────────────────────────

# [REQUIRED*] Apple Developer team identifier. Visible in the top-right of
# developer.apple.com/account once membership is active. Used by EAS Build
# to sign builds for the App Store. Live value for Upskill Energy Limited:
APPLE_TEAM_ID="645XBAPVHK"

# [REQUIRED*] APNs auth key id — printed on the Keys page after generation.
# Pairs with `AuthKey_<KEY_ID>.p8` in the secrets store. Used by Expo /
# RevenueCat / any push backend to sign APNs JWTs. Live value:
APPLE_APNS_KEY_ID="J748RK82Z7"

# [REQUIRED*] Path to the .p8 private key file (NOT committed). Stored under
# `secrets/AuthKey_<KEY_ID>.p8` locally (gitignored) and uploaded to EAS as
# a credential. Apple only allows download once — keep a backup in 1Password
# and offline.
APPLE_APNS_KEY_PATH="./secrets/AuthKey_J748RK82Z7.p8"

# [REQUIRED*] Apple ID used to sign App Store Connect — used by EAS submit.
APPLE_ID="cj@upskillenergy.com"

# [REQUIRED*] App Store Connect app id (numeric). Populated AFTER the app
# record is created — App Store Connect → My Apps → The English Hub →
# App Information → Apple ID. Until then, EAS submit cannot push to ASC.
APPLE_ASC_APP_ID="6765644554"

# [REQUIRED*] App Store Connect API key — used by RevenueCat (NOT by our
# server) to fetch IAP product metadata, validate receipts, and read sales
# reports. The .p8 file lives at `secrets/AuthKey_<KEY_ID>.p8` and is
# uploaded to RevenueCat's iOS app config; our backend never reads it
# directly. Both Key ID and Issuer ID are required by RC alongside the .p8.
APPLE_ASC_API_KEY_ID="3ZUP487476"
APPLE_ASC_API_KEY_ISSUER_ID="96c4e333-5841-4a2a-a3c6-731ab3770166"
APPLE_ASC_API_KEY_PATH="./secrets/AuthKey_3ZUP487476.p8"

# ── Trustpilot (review invitations + TrustBox widget) ──────────────────────

# [OPTIONAL] Master switch for Trustpilot invitation sending (server-side cron).
# Real value: "true" (production). Leave "false" or unset to suppress sends.
TRUSTPILOT_ENABLED="true"

# [OPTIONAL] BCC invite email — Trustpilot generates a per-account address that,
# when BCC'd on any transactional email, triggers an invitation to the recipient.
# Live value for Upskill Energy Limited (disclosed in business-docs):
TRUSTPILOT_INVITE_EMAIL="theenglishhub.app+45777e1d0c@invite.trustpilot.com"

# [OPTIONAL] Public-safe Trustpilot InviteJS integration key for the browser
# widget. Exposed in the client bundle by design.
NEXT_PUBLIC_TRUSTPILOT_INVITE_KEY="v5nUhdVBgegtcCLG"

# [OPTIONAL] Public-safe Trustpilot Business Unit ID used by the TrustBox
# widget on the homepage and /for-schools.
NEXT_PUBLIC_TRUSTPILOT_BUSINESS_UNIT_ID="69e9a869c2bb1d03a6752578"

# [OPTIONAL] Trustpilot site verification ID (for domain ownership proof).
# Pending — populate once Trustpilot issues the value.
NEXT_PUBLIC_TRUSTPILOT_VERIFICATION_ID=""

# ── Search engine verification ─────────────────────────────────────────────

# [OPTIONAL] Google Search Console verification (set after adding the meta
# verification method in GSC). When unset, no meta tag is emitted.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# [OPTIONAL] Bing Webmaster verification (set after adding the meta
# verification method in Bing Webmaster). When unset, no meta tag is emitted.
NEXT_PUBLIC_BING_SITE_VERIFICATION=
