# ============================================================================
# The English Hub - Environment Variables
# ============================================================================
# Copy this file to .env.local for local development.
# In production, set these in Vercel Dashboard > Settings > Environment Variables.
#
# Legend:
#   [REQUIRED]  - App will crash in production without this
#   [REQUIRED*] - Feature-critical; app starts but key functionality breaks
#   [OPTIONAL]  - App works without it; logs a warning at startup
# ============================================================================

# ── Supabase ────────────────────────────────────────────────────────────────

# [REQUIRED] Supabase project URL (Settings > API > Project URL)
NEXT_PUBLIC_SUPABASE_URL=

# [REQUIRED] Supabase anonymous/public API key (Settings > API > anon key)
# Safe to expose client-side; all access is governed by RLS policies.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# [REQUIRED] Supabase service role key (Settings > API > service_role key)
# SERVER-ONLY. Bypasses RLS -- never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ── Prisma / Database ──────────────────────────────────────────────────────

# [REQUIRED*] PostgreSQL connection string for Prisma ORM
# Format: postgresql://user:password@host:port/dbname
# Get this from Supabase Dashboard > Settings > Database > Connection string
DATABASE_URL=

# ── Stripe (Payments) ──────────────────────────────────────────────────────

# [REQUIRED] Stripe publishable key (client-side, safe to expose)
# Use test key (pk_test_...) for development, live key (pk_live_...) for production.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# [REQUIRED] Stripe secret key (server-only)
# Use test key (sk_test_...) for development, live key (sk_live_...) for production.
STRIPE_SECRET_KEY=

# [REQUIRED] Stripe webhook signing secret
# From Stripe Dashboard > Developers > Webhooks > your endpoint > Signing secret.
# Different for each endpoint (test vs live, local vs production).
STRIPE_WEBHOOK_SECRET=

# ── Stripe Price IDs ───────────────────────────────────────────────────────
# [OPTIONAL] Each maps to a Stripe Price object. Create in Stripe Dashboard > Products.
# Without these, the corresponding course/subscription won't appear in pricing.

# Pro subscription plans
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=

# AQA KS3 one-time courses
STRIPE_PRICE_KS3_READING=
STRIPE_PRICE_KS3_WRITING=
STRIPE_PRICE_KS3_GRAMMAR=

# AQA GCSE one-time courses
STRIPE_PRICE_GCSE_LANG_READING=
STRIPE_PRICE_GCSE_LANG_WRITING=
STRIPE_PRICE_GCSE_LIT_POETRY=
STRIPE_PRICE_GCSE_LIT_PROSE=
STRIPE_PRICE_GCSE_REVISION=

# Course bundle
STRIPE_PRICE_BUNDLE=

# Edexcel one-time courses
STRIPE_PRICE_EDEXCEL_LANG_P1=
STRIPE_PRICE_EDEXCEL_LANG_P2=
STRIPE_PRICE_EDEXCEL_LIT_P1=
STRIPE_PRICE_EDEXCEL_LIT_P2=
STRIPE_PRICE_EDEXCEL_IGCSE_A=
STRIPE_PRICE_EDEXCEL_IGCSE_B=

# ── AI / Anthropic ─────────────────────────────────────────────────────────

# [REQUIRED] Anthropic API key for Claude (essay feedback, AI features)
# From console.anthropic.com > API Keys
ANTHROPIC_API_KEY=

# ── Email (Resend) ─────────────────────────────────────────────────────────

# [REQUIRED*] Resend API key for transactional emails (welcome, password reset,
# weekly reports, dormancy warnings, school access alerts)
# From resend.com > API Keys
RESEND_API_KEY=

# ── Site URLs ──────────────────────────────────────────────────────────────

# [REQUIRED*] Public-facing app URL (used in emails, redirects, Open Graph tags)
NEXT_PUBLIC_APP_URL=https://theenglishhub.app

# [REQUIRED*] Site URL used in transactional email templates
NEXT_PUBLIC_SITE_URL=https://theenglishhub.app

# ── Security ───────────────────────────────────────────────────────────────

# [REQUIRED*] HMAC secret for CSRF token generation/validation
# Generate with: openssl rand -hex 32
CSRF_SECRET=

# [REQUIRED*] Salt for privacy-compliant IP address hashing
# Generate with: openssl rand -hex 16
IP_HASH_SALT=

# Affiliate click IP deduplication — HMAC-SHA256 hash of client IP
# Generate a strong 32+ character random string. Each environment
# (prod, staging) should have its own unique value. A rotating secret
# breaks cross-environment click-fraud deduplication but does not
# break already-persisted rows.
AFFILIATE_IP_HASH_SECRET=

# Cookie-consent IP hash — same purpose, different trust boundary.
# Keep distinct from AFFILIATE_IP_HASH_SECRET.
CONSENT_IP_HASH_SECRET=

# ── Cron Jobs ──────────────────────────────────────────────────────────────

# [REQUIRED*] Secret token for authenticating cron job requests
# Auto-set by Vercel on Pro/Enterprise plans. Set manually for local testing.
# Cron endpoints verify: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# ── Rate Limiting (Upstash Redis) ──────────────────────────────────────────

# [REQUIRED*] Upstash Redis REST endpoint and token for API rate limiting
# From console.upstash.com > your database > REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Admin ──────────────────────────────────────────────────────────────────

# [OPTIONAL] Comma-separated email addresses with admin access
ADMIN_EMAILS=admin@example.com

# [OPTIONAL] Comma-separated list of site-wide super-admin emails
SITE_ADMIN_EMAILS=admin@example.com

# ── Affiliate Tracking (Rewardful) ────────────────────────────────────────

# [OPTIONAL] Rewardful server-side API key (from Rewardful dashboard)
REWARDFUL_API_SECRET=

# [OPTIONAL] Rewardful client-side key (safe to expose, used for JS snippet)
NEXT_PUBLIC_REWARDFUL_KEY=

# [OPTIONAL] Email address for affiliate admin notifications
AFFILIATE_ADMIN_EMAIL=affiliates@theenglishhub.app

# ── Error Tracking (Sentry) ───────────────────────────────────────────────

# [OPTIONAL] Sentry DSN for client-side error reporting
NEXT_PUBLIC_SENTRY_DSN=

# [OPTIONAL] Sentry DSN for server-side error reporting
SENTRY_DSN=

# ── Analytics ──────────────────────────────────────────────────────────────

# [OPTIONAL] Google Analytics 4 measurement ID
# GA4 snippet is only injected when this is set.
NEXT_PUBLIC_GA4_ID=
