# ──────────────────────────────────────────────────────────────
# English Hub Backend — Environment Variables
# Copy to .env for local development. In Azure, set via App Settings.
# ──────────────────────────────────────────────────────────────

# Server
PORT=8080
NODE_ENV=development

# Database — Azure Database for PostgreSQL Flexible Server
DB_HOST=localhost
DB_PORT=5432
DB_NAME=english_hub
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
# Alternative: full connection string (takes precedence if set)
# DB_CONNECTION_STRING=postgresql://user:pass@host:5432/dbname?sslmode=require

# Auth
JWT_SECRET=change-me-to-a-64-char-random-string
JWT_EXPIRES_IN=7d
COOKIE_DOMAIN=localhost

# Frontend
FRONTEND_URL=http://localhost:3000

# Stripe (for webhook verification)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug
